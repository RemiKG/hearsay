{
  "name": "hearsay",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hearsay — an adversarial AI courtroom that hears the side you didn't type. A society of Qwen agents (Clerk, opposed Counsels, a vote-changing Jury, a grounding Cross-examiner) over a deterministic Bench that judges the deed, not the storyteller.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c ochre,slate \"vite\" \"tsx watch server/index.ts\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build && node scripts/build-server.mjs",
    "start": "node dist-server/index.js",
    "preview": "npm run build && npm start",
    "typecheck": "tsc --noEmit",
    "mcp": "tsx mcp/comms-mcp/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
