# ─── Hearsay environment ─────────────────────────────────────────────────────
# Copy to `.env` and fill in. NOTHING here is committed (.env is gitignored).
# The app runs WITHOUT any of these — it degrades honestly to a clearly-labelled
# demo engine. Every value below activates a real path the moment it exists.

# ── The engine: Qwen Cloud (Alibaba Cloud Model Studio) ──────────────────────
# A plain pay-as-you-go `sk-` key from https://home.qwencloud.com/api-keys
# (NOT a `sk-sp-` Token-Plan key — those can't back a deployed backend).
# When set, the whole society reasons on live Qwen models. When empty, Hearsay
# runs the deterministic demo engine and says so, in the UI.
DASHSCOPE_API_KEY=

# OpenAI-compatible base URL for the international (Singapore) endpoint.
# Leave as-is unless Alibaba changes it.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Per-role model routing (defaults match the design; override to experiment).
HEARSAY_MODEL_CLERK=qwen3.7-max
HEARSAY_MODEL_COUNSEL=qwen3.6-flash
HEARSAY_MODEL_JURY=qwen3.7-plus
HEARSAY_MODEL_CROSS=qwen3.7-plus
HEARSAY_MODEL_VISION=qwen3-vl-plus
HEARSAY_MODEL_SOLO=qwen3.7-max

# Real-world grounding (Cross-examiner). `web_extractor` is free; `web_search`
# is billed. Set to `off` to disable grounding entirely.
HEARSAY_GROUNDING=web_extractor

# ── comms-MCP: deliver the verdict card + the "tell your side" invite ────────
# Telegram Bot API token (https://t.me/BotFather). Delivery is skipped honestly
# if unset.
TELEGRAM_BOT_TOKEN=
# SMTP for email delivery of the verdict card / invite link.
SMTP_URL=
SMTP_FROM=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787
# Public origin used only to build absolute share/invite links inside emails and
# Telegram messages (never used by browser client code). Optional.
PUBLIC_ORIGIN=
